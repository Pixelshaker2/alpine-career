# =============================================================================
# alpine-career — Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und fuege die echten Werte ein.
# NIEMALS .env ins Repository committen!
# =============================================================================

# --- Applikation ---
APP_NAME=alpine-career
APP_ENV=development                  # development | staging | production
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=                      # Zufaelliger String, min. 32 Zeichen

# --- Datenbank (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alpine_career
POSTGRES_USER=alpine_career
POSTGRES_PASSWORD=                   # Sicheres Passwort setzen
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Cache / Queue (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# --- Authentication (Google OAuth 2.0) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- JWT ---
JWT_SECRET_KEY=                      # Zufaelliger String, min. 64 Zeichen
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI (Claude API) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# --- Integrationen ---
GMAIL_CREDENTIALS_FILE=              # Pfad zur Google OAuth credentials.json
GOOGLE_DRIVE_CREDENTIALS_FILE=
TELEGRAM_BOT_TOKEN=                  # Von @BotFather erhalten
TELEGRAM_ALLOWED_USERNAMES=dorender   # Komma-getrennt, nur diese User duerfen den Bot nutzen

# --- Adzuna API (Job-Suche) ---
ADZUNA_APP_ID=                       # Von developer.adzuna.com
ADZUNA_APP_KEY=                      # Von developer.adzuna.com

# --- Logging ---
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                      # json | console

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Traefik (nur Production) ---
DOMAIN=                              # z.B. alpine-career.ch
ACME_EMAIL=                          # E-Mail fuer Let's Encrypt
